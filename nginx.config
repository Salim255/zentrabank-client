server {

    # =========================
    # 1. LISTENING PORT
    # =========================
    listen 80;
    # Nginx listens on port 80 (HTTP).
    # This is the entry point for all browser requests.

    # =========================
    # 2. SERVER NAME
    # =========================
    server_name _;
    # "_" means "catch-all server".
    # This server will respond to ANY domain pointing to this machine.
    # Useful for Docker, VPS, or when domain is not strictly enforced.

    # =========================
    # 3. ROOT DIRECTORY
    # =========================
    root /usr/share/nginx/html;
    # This is where Angular build files are stored.
    # Example: index.html, main.js, styles.css

    # =========================
    # 4. DEFAULT ENTRY FILE
    # =========================
    index index.html;
    # When visiting "/", Nginx serves index.html first.

    # =========================
    # 5. ANGULAR SPA ROUTING FIX
    # =========================
    location / {

        # try_files checks files in order:
        # 1. $uri → exact file match (e.g. /assets/logo.png)
        # 2. $uri/ → directory match
        # 3. /index.html → fallback for Angular routes

        try_files $uri $uri/ /index.html;

        # WHY THIS IS IMPORTANT:
        # Angular is a Single Page Application (SPA).
        # Routes like /dashboard or /accounts do NOT exist on server.
        # Without this, refreshing a page would give 404 error.
    }

    # =========================
    # 6. SECURITY HEADERS
    # =========================

    # Prevents browser from guessing file types incorrectly.
    # Helps protect against certain XSS attacks.
    add_header X-Content-Type-Options nosniff;

    # Prevents your site from being embedded inside an iframe.
    # Protects against clickjacking attacks.
    add_header X-Frame-Options DENY;

    # Basic XSS protection for older browsers.
    # Modern browsers mostly rely on CSP instead.
    add_header X-XSS-Protection "1; mode=block";

    # =========================
    # 7. STATIC FILE CACHING
    # =========================
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg)$ {

        # expires 30d:
        # tells browser to cache files for 30 days.
        # reduces server load and improves performance.

        expires 30d;

        # Cache-Control header:
        # "public" → can be cached by browser + CDN
        # "no-transform" → prevents proxy modifications
        add_header Cache-Control "public, no-transform";
    }
}
